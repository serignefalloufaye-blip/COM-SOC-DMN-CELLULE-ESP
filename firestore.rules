rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "serignefalloufaye@esp.sn" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidMembre(data) {
      return data.prenom is string && data.prenom.size() > 0 && data.prenom.size() < 100 &&
             data.nom is string && data.nom.size() > 0 && data.nom.size() < 100 &&
             (!('telephone' in data) || (data.telephone is string && data.telephone.size() < 20)) &&
             (!('statut' in data) || (data.statut in ['Boursier', 'Non Boursier', 'Professionnel', 'Autre']));
    }

    function isValidCotisation(data) {
      return data.mId is string && data.mId.size() > 0 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0 &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'];
    }

    function isValidDepense(data) {
      return data.evenement is string && data.evenement.size() > 0 && data.evenement.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0;
    }

    function isValidRecette(data) {
      return data.motif is string && data.motif.size() > 0 && data.motif.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0 &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'];
    }

    function isValidDette(data) {
      return data.motif is string && data.motif.size() > 0 && data.motif.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0;
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'visitor'];
    }

    function isValidSettings(data) {
      return data.logoUrl is string && data.logoUrl.size() < 1048576; // 1MB limit for Base64
    }

    // Rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /membres/{membreId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidMembre(request.resource.data);
      allow update: if isAdmin() && isValidMembre(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cotisations/{cotisationId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidCotisation(request.resource.data);
      allow update: if isAdmin() && isValidCotisation(request.resource.data);
      allow delete: if isAdmin();
    }

    match /depenses/{depenseId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidDepense(request.resource.data);
      allow update: if isAdmin() && isValidDepense(request.resource.data);
      allow delete: if isAdmin();
    }

    match /recettes/{recetteId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidRecette(request.resource.data);
      allow update: if isAdmin() && isValidRecette(request.resource.data);
      allow delete: if isAdmin();
    }

    match /dettes/{detteId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidDette(request.resource.data);
      allow update: if isAdmin() && isValidDette(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
