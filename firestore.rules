rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'lecteur';
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "serignefalloufaye@esp.sn" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isCaisse() {
      return isAdmin() || (isAuthenticated() && getRole() == 'caisse');
    }

    function isTickets() {
      return isAdmin() || (isAuthenticated() && getRole() == 'tickets');
    }

    function isCafe() {
      return isAdmin() || (isAuthenticated() && getRole() == 'cafe');
    }

    function isLecteur() {
      return isAuthenticated() && getRole() in ['lecteur', 'admin', 'caisse', 'tickets', 'cafe'];
    }

    // --- Domain Validators ---
    function isValidMembre(data) {
      return data.prenom is string && data.prenom.size() > 0 && data.prenom.size() < 100 &&
             data.nom is string && data.nom.size() > 0 && data.nom.size() < 100 &&
             (!('telephone' in data) || (data.telephone is string && data.telephone.size() < 20)) &&
             (!('statut' in data) || (data.statut in ['Boursier', 'Non Boursier', 'Professionnel', 'Autre']));
    }

    function isValidCotisation(data) {
      return data.mId is string && data.mId.size() > 0 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0 &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'];
    }

    function isValidDepense(data) {
      return data.evenement is string && data.evenement.size() > 0 && data.evenement.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0;
    }

    function isValidRecette(data) {
      return data.motif is string && data.motif.size() > 0 && data.motif.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0 &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'];
    }

    function isValidDette(data) {
      return data.motif is string && data.motif.size() > 0 && data.motif.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string && data.email.size() > 0 &&
             data.nom is string &&
             data.role in ['admin', 'caisse', 'tickets', 'cafe', 'lecteur'];
    }

    function isValidAccessCode(data) {
      return data.code is string && 
             data.role in ['caisse', 'tickets', 'cafe'] &&
             data.used is bool &&
             data.createdAt is number;
    }

    function isValidTicketCollecte(data) {
      return data.mId is string && data.mId.size() > 0 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.type in ['argent', 'tickets'] &&
             data.montantArgent is number && data.montantArgent >= 0 &&
             data.petitDej is number && data.petitDej >= 0 &&
             data.repas is number && data.repas >= 0 &&
             data.createdAt is number;
    }

    function isValidTicketConversion(data) {
      return data.montant is number && data.montant > 0 &&
             data.petitDej is number && data.petitDej >= 0 &&
             data.repas is number && data.repas >= 0 &&
             data.createdAt is number;
    }

    function isValidTicketDistribution(data) {
      return (!('mId' in data) || (data.mId is string)) &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.petitDej is number && data.petitDej >= 0 &&
             data.repas is number && data.repas >= 0 &&
             data.createdAt is number;
    }

    function isValidAuditLog(data) {
      return data.userId is string && data.action is string && data.createdAt is number;
    }

    // --- Rules ---

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /membres/{membreId} {
      allow read: if isLecteur();
      allow create, update: if isCaisse() && isValidMembre(incoming());
      allow delete: if isAdmin();
    }

    match /cotisations/{id} {
      allow read: if isLecteur();
      allow create, update: if isCaisse() && isValidCotisation(incoming());
      allow delete: if isAdmin();
    }

    match /depenses/{id} {
      allow read: if isLecteur();
      allow create, update: if isCaisse() && isValidDepense(incoming());
      allow delete: if isAdmin();
    }

    match /recettes/{id} {
      allow read: if isLecteur();
      allow create, update: if isCaisse() && isValidRecette(incoming());
      allow delete: if isAdmin();
    }

    match /dettes/{id} {
      allow read: if isLecteur();
      allow create, update: if isCaisse() && isValidDette(incoming());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if (isAuthenticated() && request.auth.uid == userId && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['nom', 'email', 'avatarUrl', 'role'])) || 
                    (isAdmin() && isValidUser(incoming()));
      allow delete: if isAdmin();
    }

    match /access_codes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidAccessCode(incoming());
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.used == false && 
        incoming().diff(existing()).affectedKeys().hasOnly(['used', 'usedBy', 'usedByName'])
      );
      allow delete: if isAdmin();
    }

    // Tickets
    match /tickets_collectes/{id} {
      allow read: if isLecteur();
      allow create, update: if isTickets() && isValidTicketCollecte(incoming());
      allow delete: if isTickets();
    }

    match /tickets_conversions/{id} {
      allow read: if isLecteur();
      allow create, update: if isTickets() && isValidTicketConversion(incoming());
      allow delete: if isTickets();
    }

    match /tickets_distributions/{id} {
      allow read: if isLecteur();
      allow create, update: if isTickets() && isValidTicketDistribution(incoming());
      allow delete: if isTickets();
    }

    // Cafe
    match /cafe_productions/{id} {
      allow read: if isLecteur();
      allow create, update: if isCafe() && incoming().keys().hasAll(['date', 'quantite']);
      allow delete: if isCafe();
    }

    match /cafe_ventes/{id} {
      allow read: if isLecteur();
      allow create, update: if isCafe() && incoming().keys().hasAll(['date', 'quantite', 'total']);
      allow delete: if isCafe();
    }

    match /cafe_depenses/{id} { allow read: if isLecteur(); allow write: if isCafe(); }
    match /cafe_transferts/{id} { allow read: if isLecteur(); allow write: if isCafe(); }
    match /cafe_distributions/{id} { allow read: if isLecteur(); allow write: if isCafe(); }
    match /cafe_versements/{id} { allow read: if isLecteur(); allow write: if isCafe(); }
    match /cafe_sellers/{id} { allow read: if isLecteur(); allow write: if isCafe(); }
    match /cafe_clients/{id} { allow read: if isLecteur(); allow write: if isCafe(); }
    match /cafe_orders/{id} { allow read: if isLecteur(); allow write: if isCafe(); }

    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidAuditLog(incoming());
      allow update, delete: if false;
    }
  }
}
