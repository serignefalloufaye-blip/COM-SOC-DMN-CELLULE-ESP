rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "serignefalloufaye@esp.sn" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : 'lecteur';
    }

    function isCaisse() {
      return isAdmin() || (isAuthenticated() && getRole() == 'caisse');
    }

    function isTickets() {
      return isAdmin() || (isAuthenticated() && getRole() == 'tickets');
    }

    function isCafe() {
      return isAdmin() || (isAuthenticated() && getRole() == 'cafe');
    }

    function isLecteur() {
      return isAuthenticated();
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidMembre(data) {
      return data.prenom is string && data.prenom.size() > 0 && data.prenom.size() < 100 &&
             data.nom is string && data.nom.size() > 0 && data.nom.size() < 100 &&
             (!('telephone' in data) || (data.telephone is string && data.telephone.size() < 20)) &&
             (!('statut' in data) || (data.statut in ['Boursier', 'Non Boursier', 'Professionnel', 'Autre']));
    }

    function isValidCotisation(data) {
      return data.mId is string && data.mId.size() > 0 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0 &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'];
    }

    function isValidDepense(data) {
      return data.evenement is string && data.evenement.size() > 0 && data.evenement.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0;
    }

    function isValidRecette(data) {
      return data.motif is string && data.motif.size() > 0 && data.motif.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0 &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'];
    }

    function isValidDette(data) {
      return data.motif is string && data.motif.size() > 0 && data.motif.size() < 200 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.montant is number && data.montant >= 0;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string && data.email.size() > 0 &&
             data.nom is string &&
             data.role in ['admin', 'caisse', 'tickets', 'cafe', 'lecteur'];
    }

    function isValidAccessCode(data) {
      return data.code is string && 
             data.role in ['caisse', 'tickets', 'cafe'] &&
             data.used is bool &&
             data.createdAt is number;
    }

    function isValidSettings(data) {
      return data.logoUrl is string && data.logoUrl.size() < 1048576; // 1MB limit for Base64
    }

    function isValidTicketCollecte(data) {
      return data.mId is string && data.mId.size() > 0 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.type in ['argent', 'tickets'] &&
             data.montantArgent is number && data.montantArgent >= 0 &&
             data.petitDej is number && data.petitDej >= 0 &&
             data.repas is number && data.repas >= 0 &&
             data.createdAt is number;
    }

    function isValidTicketConversion(data) {
      return data.montant is number && data.montant > 0 &&
             data.petitDej is number && data.petitDej >= 0 &&
             data.repas is number && data.repas >= 0 &&
             data.createdAt is number;
    }

    function isValidTicketDistribution(data) {
      return data.mId is string && data.mId.size() > 0 &&
             data.mois is string && data.mois.size() > 0 && data.mois.size() < 20 &&
             data.annee is number && data.annee > 2000 && data.annee < 2100 &&
             data.petitDej is number && data.petitDej >= 0 &&
             data.repas is number && data.repas >= 0 &&
             data.createdAt is number;
    }

    function isValidCafeProduction(data) {
      return data.date is number &&
             data.quantite is number && data.quantite >= 0 &&
             data.coutUnitaire is number && data.coutUnitaire >= 0 &&
             (!('typeCafe' in data) || (data.typeCafe is string && data.typeCafe.size() < 100)) &&
             data.total is number && data.total >= 0;
    }

    function isValidCafeVente(data) {
      return data.date is number &&
             data.quantite is number && data.quantite > 0 &&
             data.prixUnitaire is number && data.prixUnitaire >= 0 &&
             (!('typeCafe' in data) || (data.typeCafe is string && data.typeCafe.size() < 100)) &&
             (!('typeVente' in data) || (data.typeVente in ['Sur place', 'Commande'])) &&
             (!('vendeurId' in data) || (data.vendeurId is string)) &&
             (!('clientId' in data) || (data.clientId is string)) &&
             data.total is number && data.total >= 0 &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'] &&
             (!('createdAt' in data) || (data.createdAt is number));
    }

    function isValidCafeDistribution(data) {
      return data.date is number &&
             data.celluleId is string && data.celluleId.size() > 0 &&
             data.typeCafe is string && data.typeCafe.size() > 0 &&
             data.quantite is number && data.quantite > 0 &&
             data.prixUnitaire is number && data.prixUnitaire >= 0 &&
             data.total is number && data.total >= 0 &&
             data.createdAt is number;
    }

    function isValidCafeVersement(data) {
      return data.date is number &&
             data.vendeurId is string && data.vendeurId.size() > 0 &&
             data.montant is number && data.montant > 0 &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'] &&
             data.createdAt is number;
    }

    function isValidCafeDepense(data) {
      return data.date is number &&
             data.motif is string && data.motif.size() > 0 && data.motif.size() < 200 &&
             (!('categorie' in data) || (data.categorie in ['Matières premières', 'Transport', 'Autres'])) &&
             data.montant is number && data.montant >= 0;
    }

    function isValidCafeTransfert(data) {
      return data.date is number &&
             data.montant is number && data.montant > 0 &&
             (!('message' in data) || (data.message is string && data.message.size() < 500));
    }

    function isValidCafeSeller(data) {
      return data.nom is string && data.nom.size() > 0 &&
             (!('telephone' in data) || (data.telephone is string && data.telephone.size() < 20)) &&
             data.active is bool &&
             data.createdAt is number;
    }

    function isValidCafeClient(data) {
      return data.nom is string && data.nom.size() > 0 &&
             (!('telephone' in data) || (data.telephone is string && data.telephone.size() < 20)) &&
             data.totalAchats is number &&
             (!('lastAchat' in data) || (data.lastAchat is number)) &&
             data.createdAt is number;
    }

    function isValidCafeOrder(data) {
      return (!('clientId' in data) || (data.clientId is string)) &&
             (!('clientNom' in data) || (data.clientNom is string)) &&
             (!('vendeurId' in data) || (data.vendeurId is string)) &&
             data.quantite is number && data.quantite > 0 &&
             data.prixUnitaire is number && data.prixUnitaire >= 0 &&
             data.total is number && data.total >= 0 &&
             data.statut in ['en_attente', 'validee', 'livree', 'annulee'] &&
             data.date is number &&
             data.mode in ['WAVE', 'OM', 'ESPÈCES'] &&
             data.createdAt is number;
    }

    // Rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /membres/{membreId} {
      allow read: if isLecteur();
      allow create: if isCaisse() && isValidMembre(request.resource.data);
      allow update: if isCaisse() && isValidMembre(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cotisations/{cotisationId} {
      allow read: if isLecteur();
      allow create: if isCaisse() && isValidCotisation(request.resource.data);
      allow update: if isCaisse() && isValidCotisation(request.resource.data);
      allow delete: if isAdmin();
    }

    match /depenses/{depenseId} {
      allow read: if isLecteur();
      allow create: if isCaisse() && isValidDepense(request.resource.data);
      allow update: if isCaisse() && isValidDepense(request.resource.data);
      allow delete: if isAdmin();
    }

    match /recettes/{recetteId} {
      allow read: if isLecteur();
      allow create: if isCaisse() && isValidRecette(request.resource.data);
      allow update: if isCaisse() && isValidRecette(request.resource.data);
      allow delete: if isAdmin();
    }

    match /dettes/{detteId} {
      allow read: if isLecteur();
      allow create: if isCaisse() && isValidDette(request.resource.data);
      allow update: if isCaisse() && isValidDette(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if (isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data)) || 
                    (isAdmin() && isValidUser(request.resource.data)) ||
                    (isAuthenticated() && request.auth.uid == userId && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']));
      allow delete: if isAdmin();
    }

    match /access_codes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidAccessCode(request.resource.data);
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.used == false && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy', 'usedByName'])
      );
      allow delete: if isAdmin();
    }

    match /tickets_collectes/{id} {
      allow read: if isAuthenticated();
      allow create: if isTickets() && isValidTicketCollecte(request.resource.data);
      allow update: if isTickets() && isValidTicketCollecte(request.resource.data);
      allow delete: if isAdmin();
    }

    match /tickets_conversions/{id} {
      allow read: if isAuthenticated();
      allow create: if isTickets() && isValidTicketConversion(request.resource.data);
      allow update: if isTickets() && isValidTicketConversion(request.resource.data);
      allow delete: if isAdmin();
    }

    match /tickets_distributions/{id} {
      allow read: if isAuthenticated();
      allow create: if isTickets() && isValidTicketDistribution(request.resource.data);
      allow update: if isTickets() && isValidTicketDistribution(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_productions/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeProduction(request.resource.data);
      allow update: if isCafe() && isValidCafeProduction(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_ventes/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeVente(request.resource.data);
      allow update: if isCafe() && isValidCafeVente(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_depenses/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeDepense(request.resource.data);
      allow update: if isCafe() && isValidCafeDepense(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_transferts/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeTransfert(request.resource.data);
      allow update: if isCafe() && isValidCafeTransfert(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_distributions/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeDistribution(request.resource.data);
      allow update: if isCafe() && isValidCafeDistribution(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_versements/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeVersement(request.resource.data);
      allow update: if isCafe() && isValidCafeVersement(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_sellers/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeSeller(request.resource.data);
      allow update: if isCafe() && isValidCafeSeller(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_clients/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeClient(request.resource.data);
      allow update: if isCafe() && isValidCafeClient(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cafe_orders/{id} {
      allow read: if isAuthenticated();
      allow create: if isCafe() && isValidCafeOrder(request.resource.data);
      allow update: if isCafe() && isValidCafeOrder(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
