{
  "entities": {
    "Membre": {
      "title": "Membre",
      "description": "Un membre de la caisse",
      "type": "object",
      "properties": {
        "prenom": { "type": "string" },
        "nom": { "type": "string" },
        "telephone": { "type": "string" },
        "statut": { "type": "string", "enum": ["Boursier", "Non Boursier", "Professionnel", "Autre"] }
      },
      "required": ["prenom", "nom"]
    },
    "Cotisation": {
      "title": "Cotisation",
      "description": "Paiement mensuel d'un membre",
      "type": "object",
      "properties": {
        "mId": { "type": "string", "description": "ID du membre" },
        "mois": { "type": "string" },
        "annee": { "type": "number" },
        "montant": { "type": "number" },
        "mode": { "type": "string", "enum": ["WAVE", "OM", "ESPÈCES"] }
      },
      "required": ["mId", "mois", "annee", "montant", "mode"]
    },
    "Depense": {
      "title": "Depense",
      "description": "Dépense de la caisse",
      "type": "object",
      "properties": {
        "evenement": { "type": "string" },
        "mois": { "type": "string" },
        "annee": { "type": "number" },
        "montant": { "type": "number" }
      },
      "required": ["evenement", "mois", "annee", "montant"]
    },
    "Recette": {
      "title": "Recette",
      "description": "Autre entrée d'argent dans la caisse",
      "type": "object",
      "properties": {
        "motif": { "type": "string" },
        "mois": { "type": "string" },
        "annee": { "type": "number" },
        "montant": { "type": "number" },
        "mode": { "type": "string", "enum": ["WAVE", "OM", "ESPÈCES"] }
      },
      "required": ["motif", "mois", "annee", "montant", "mode"]
    },
    "User": {
      "title": "User",
      "description": "Utilisateur de la plateforme avec rôle spécifique",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "nom": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "caisse", "tickets", "cafe", "lecteur"] }
      },
      "required": ["uid", "email", "nom", "role"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "description": "Code permettant d'obtenir un rôle spécifique",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "role": { "type": "string" },
        "used": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["code", "role", "used", "createdAt"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Paramètres de l'application",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string", "description": "URL ou Base64 du logo" }
      },
      "required": ["logoUrl"]
    },
    "CafeProduction": {
      "title": "Production de Café",
      "description": "Enregistrement d'une séance de production",
      "type": "object",
      "properties": {
        "date": { "type": "number" },
        "quantite": { "type": "number", "description": "Nombre de paquets/unités" },
        "coutUnitaire": { "type": "number" },
        "typeCafe": { "type": "string" },
        "total": { "type": "number" }
      },
      "required": ["date", "quantite", "coutUnitaire", "total"]
    },
    "CafeVente": {
      "title": "Vente de Café",
      "description": "Enregistrement d'une vente de café",
      "type": "object",
      "properties": {
        "date": { "type": "number" },
        "quantite": { "type": "number" },
        "prixUnitaire": { "type": "number" },
        "typeCafe": { "type": "string" },
        "typeVente": { "type": "string" },
        "vendeurId": { "type": "string" },
        "clientId": { "type": "string" },
        "total": { "type": "number" },
        "mode": { "type": "string", "enum": ["ESPÈCES", "WAVE", "OM"] }
      },
      "required": ["date", "quantite", "prixUnitaire", "total", "mode"]
    },
    "CafeDistribution": {
      "title": "Distribution de Café",
      "description": "Distribution de stock de café vers une cellule/vendeur",
      "type": "object",
      "properties": {
        "date": { "type": "number" },
        "celluleId": { "type": "string" },
        "typeCafe": { "type": "string" },
        "quantite": { "type": "number" },
        "prixUnitaire": { "type": "number" },
        "total": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["date", "celluleId", "typeCafe", "quantite", "prixUnitaire", "total", "createdAt"]
    },
    "CafeDepense": {
      "title": "Dépense Café",
      "description": "Frais de fonctionnement liés au café (sucre, gaz, etc)",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "motif": { "type": "string" },
        "montant": { "type": "number" }
      },
      "required": ["date", "motif", "montant"]
    },
    "CafeTransfert": {
      "title": "Transfert Café vers Caisse",
      "description": "Versement des bénéfices du café vers la caisse sociale",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "montant": { "type": "number" },
        "message": { "type": "string" }
      },
      "required": ["date", "montant"]
    },
    "CafeSeller": {
      "title": "Vendeur de Café",
      "description": "Gestion des vendeurs de café",
      "type": "object",
      "properties": {
        "nom": { "type": "string" },
        "telephone": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["nom", "active", "createdAt"]
    },
    "CafeClient": {
      "title": "Client de Café",
      "description": "Gestion des clients de café",
      "type": "object",
      "properties": {
        "nom": { "type": "string" },
        "telephone": { "type": "string" },
        "totalAchats": { "type": "number" },
        "lastAchat": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["nom", "totalAchats", "createdAt"]
    },
    "CafeOrder": {
      "title": "Commande de Café",
      "description": "Commande passée par un client",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientNom": { "type": "string" },
        "vendeurId": { "type": "string" },
        "quantite": { "type": "number" },
        "prixUnitaire": { "type": "number" },
        "total": { "type": "number" },
        "statut": { "type": "string", "enum": ["en_attente", "validee", "livree", "annulee"] },
        "date": { "type": "number" },
        "mode": { "type": "string", "enum": ["ESPÈCES", "WAVE", "OM"] },
        "createdAt": { "type": "number" }
      },
      "required": ["quantite", "prixUnitaire", "total", "statut", "date", "mode", "createdAt"]
    },
    "CafeVersement": {
      "title": "Versement Café",
      "description": "Versement d'argent d'un revendeur vers le Daara",
      "type": "object",
      "properties": {
        "vendeurId": { "type": "string" },
        "date": { "type": "number" },
        "montant": { "type": "number" },
        "mode": { "type": "string", "enum": ["ESPÈCES", "WAVE", "OM"] },
        "createdAt": { "type": "number" }
      },
      "required": ["vendeurId", "date", "montant", "mode", "createdAt"]
    },
    "CafePriceConfig": {
      "title": "Configuration des prix du café",
      "description": "Tarifs officiels (coût, revendeur, public) pour les formats 1kg et 500g",
      "type": "object",
      "properties": {
        "prices": {
          "type": "object",
          "properties": {
            "1kg": {
              "type": "object",
              "properties": {
                "cost": { "type": "number" },
                "reseller": { "type": "number" },
                "public": { "type": "number" }
              }
            },
            "500g": {
              "type": "object",
              "properties": {
                "cost": { "type": "number" },
                "reseller": { "type": "number" },
                "public": { "type": "number" }
              }
            }
          }
        },
        "lastUpdated": { "type": "number" }
      },
      "required": ["prices", "lastUpdated"]
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/AppSettings" },
      "description": "Paramètres globaux de l'application"
    },
    "/membres/{membreId}": {
      "schema": { "$ref": "#/entities/Membre" },
      "description": "Liste des membres"
    },
    "/cotisations/{cotisationId}": {
      "schema": { "$ref": "#/entities/Cotisation" },
      "description": "Liste des cotisations"
    },
    "/depenses/{depenseId}": {
      "schema": { "$ref": "#/entities/Depense" },
      "description": "Liste des dépenses"
    },
    "/recettes/{recetteId}": {
      "schema": { "$ref": "#/entities/Recette" },
      "description": "Liste des autres entrées d'argent"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Liste des utilisateurs admin"
    },
    "/cafe_productions/{prodId}": {
      "schema": { "$ref": "#/entities/CafeProduction" },
      "description": "Suivi de la production de café"
    },
    "/cafe_ventes/{venteId}": {
      "schema": { "$ref": "#/entities/CafeVente" },
      "description": "Suivi des ventes de café"
    },
    "/cafe_depenses/{depenseId}": {
      "schema": { "$ref": "#/entities/CafeDepense" },
      "description": "Dépenses spécifiques au café"
    },
    "/cafe_transferts/{transId}": {
      "schema": { "$ref": "#/entities/CafeTransfert" },
      "description": "Transferts d'argent vers la caisse sociale"
    },
    "/cafe_distributions/{distId}": {
      "schema": { "$ref": "#/entities/CafeDistribution" },
      "description": "Distributions de café vers les cellules/vendeurs"
    },
    "/cafe_versements/{versementId}": {
      "schema": { "$ref": "#/entities/CafeVersement" },
      "description": "Versements des revendeurs"
    },
    "/cafe_sellers/{sellerId}": {
      "schema": { "$ref": "#/entities/CafeSeller" },
      "description": "Liste des vendeurs de café"
    },
    "/cafe_clients/{clientId}": {
      "schema": { "$ref": "#/entities/CafeClient" },
      "description": "Liste des clients du café"
    },
    "/cafe_orders/{orderId}": {
      "schema": { "$ref": "#/entities/CafeOrder" },
      "description": "Commandes de café"
    }
  }
}
